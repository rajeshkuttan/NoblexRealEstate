[Unit]
Description=Redis 7 for Real Estate Copilot (port 6380)
After=network.target

[Service]
Type=notify
ExecStart=/usr/bin/redis-server /etc/redis/redis-copilot.conf
ExecStop=/bin/kill -s TERM $MAINPID
Restart=always
RestartSec=3
User=redis
Group=redis
RuntimeDirectory=redis
RuntimeDirectoryMode=0755
LimitNOFILE=65535
TimeoutStartSec=30
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target

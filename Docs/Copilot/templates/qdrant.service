[Unit]
Description=Qdrant vector DB for Real Estate Copilot
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=qdrant
Group=qdrant
WorkingDirectory=/opt/qdrant
ExecStart=/opt/qdrant/qdrant --config-path /etc/qdrant/config.yaml
Restart=always
RestartSec=5
LimitNOFILE=65535
Environment=QDRANT__SERVICE__HTTP_PORT=6333
# Environment=QDRANT__SERVICE__API_KEY=CHANGE_ME_IF_REMOTE
StandardOutput=append:/var/log/qdrant/stdout.log
StandardError=append:/var/log/qdrant/stderr.log

[Install]
WantedBy=multi-user.target

# PRODUCTION ENVIRONMENT CONFIGURATION EXAMPLE
# ==========================================
# Copy this file to config.production.env and update with production settings
# cp config.production.env.example config.production.env
# 
# WARNING: NEVER commit config.production.env to version control!
# It contains sensitive credentials

# Database Configuration - PRODUCTION
# Update these with your actual production database credentials
DB_HOST=your-production-db-host.com
DB_PORT=3306
DB_NAME=Leasemanagement_prod
DB_USER=prod_user
DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Server Configuration
PORT=5002
NODE_ENV=production

# JWT Configuration - PRODUCTION
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_PRODUCTION_SECRET_KEY
JWT_EXPIRE=7d

# CORS Configuration - PRODUCTION
# Only list production frontend URLs (no localhost in production!)
CORS_ORIGIN=https://realestate.globaldes.cloud

# Rate Limiting - PRODUCTION (Stricter than development)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload - PRODUCTION
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/var/www/uploads

# Logging - PRODUCTION (Less verbose for performance)
LOG_LEVEL=warn
LOG_FILE=/var/log/emirates-lease-flow/app.log

# Email Configuration (SMTP) - PRODUCTION
# For Gmail: Use App Password (not regular password)
# For production: Consider using a professional email service like SendGrid, AWS SES, or Mailgun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-production-email@emiratesleaseflow.com
SMTP_PASSWORD=REPLACE_WITH_SECURE_APP_PASSWORD

# Email Settings - PRODUCTION
EMAIL_FROM=Emirates Lease Flow <noreply@emiratesleaseflow.com>
EMAIL_REPLY_TO=support@emiratesleaseflow.com

# ==========================================
# SECURITY CHECKLIST BEFORE DEPLOYMENT:
# ==========================================
# [ ] Updated DB_HOST with production database server
# [ ] Changed DB_NAME to production database name
# [ ] Set strong DB_PASSWORD (minimum 16 characters)
# [ ] Generated new JWT_SECRET (use: openssl rand -base64 64)
# [ ] Verified CORS_ORIGIN matches production frontend URL
# [ ] Set appropriate file permissions: chmod 600 config.production.env
# [ ] Ensured .gitignore includes config.production.env
# [ ] Tested database connection
# [ ] Verified CORS settings work with frontend
# [ ] Set up SSL/TLS certificates
# [ ] Configured firewall rules
# [ ] Set up automated backups
# [ ] Configured SMTP settings for email notifications
# [ ] Tested email functionality (password reset, notifications)
# ==========================================

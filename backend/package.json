{
  "name": "emirates-lease-flow-backend",
  "version": "1.0.0",
  "description": "Emirates Lease Flow Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker:copilot": "node src/copilot/worker.js",
    "pm2:start": "pm2 startOrReload ecosystem.config.js --env production",
    "test": "jest --coverage",
    "migrate": "node src/scripts/runMigrations.js",
    "seed": "node src/scripts/seedProductionData.js",
    "seed:phase2e": "node scripts/generate-phase2e-demo-data.js",
    "sync:rbac": "node src/scripts/sync-system-role-permissions.js",
    "performance-test": "node src/scripts/performanceTest.js",
    "seed:payroll-full-cycle": "node src/scripts/seed-payroll-full-cycle.js",
    "seed:procurement": "node src/scripts/seedProcurementData.js",
    "seed:payroll-procurement": "node src/scripts/seedPayrollAndProcurement.js",
    "validate:payroll-full-cycle": "node src/scripts/validate-payroll-full-cycle.js",
    "test:payroll-full-cycle": "jest src/tests/payroll/full-cycle/payroll-full-cycle.test.js --coverage=false",
    "seed:investments": "node src/scripts/seedInvestmentData.js",
    "seed:investments-v2": "node src/scripts/seedInvestment2Data.js",
    "seed:investments-full": "npm run seed:investments && npm run seed:investments-v2",
    "seed:property-images": "node src/scripts/seedPropertyUnitImages.js",
    "validate:investments": "node src/scripts/validateInvestmentModule.js",
    "seed:investment-posting": "node src/scripts/seed-investment-posting-fixtures.js",
    "validate:investment-posting": "node src/scripts/validate-investment-posting.js",
    "test:investment": "jest src/tests/investment --coverage=false",
    "test:investment-posting": "jest src/tests/investment/investment-posting-integration.test.js --coverage=false",
    "test:prepaid": "jest src/tests/prepaid-expenses --coverage=false",
    "seed:prepaid": "node src/scripts/seedPrepaidExpenses.js",
    "validate:prepaid": "node src/scripts/validatePrepaidExpenses.js",
    "test:lease-revenue": "jest src/tests/lease-revenue --coverage=false",
    "seed:lease-revenue": "node src/scripts/seedLeaseRevenue.js",
    "validate:lease-revenue": "node src/scripts/validateLeaseRevenue.js",
    "investment2:rc1:baseline": "node src/scripts/investment2Rc1Baseline.js",
    "investment2:rc1:migrate:dry-run": "node src/scripts/investment2Rc1MigrationDryRun.js",
    "investment2:rc1:migrate": "node src/scripts/investment2Rc1Migrate.js",
    "investment2:rc1:reconcile": "node src/scripts/investment2Rc1Reconcile.js",
    "investment2:rc1:cutover-validate": "node src/scripts/investment2Rc1CutoverValidate.js",
    "investment2:rc1:gate": "node src/scripts/investment2Rc1ReleaseGate.js",
    "investment2:rc1:rollback": "node src/scripts/investment2Rc1RollbackMigration.js",
    "release:investment2:preflight": "node src/scripts/investment2Rc1Preflight.js",
    "release:investment2:postdeploy": "node src/scripts/investment2Rc1Postdeploy.js",
    "release:investment2:gate": "node src/scripts/investment2Rc1ReleaseGate.js"
  },
  "keywords": [
    "real-estate",
    "property-management",
    "lease-management"
  ],
  "author": "Emirates Lease Flow Team",
  "license": "ISC",
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.80.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.3.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mathjs": "^11.11.2",
    "ml-regression": "^6.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.6.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.10.1",
    "papaparse": "^5.4.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.2",
    "sequelize": "^6.33.0",
    "simple-statistics": "^7.8.3",
    "stripe": "^14.10.0",
    "uuid": "^8.3.2",
    "validator": "^13.11.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.5",
    "supertest": "^6.3.3"
  }
}

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=Leasemanagement
DB_USER=root
DB_PASSWORD=

# Server Configuration
PORT=5002
NODE_ENV=development

# JWT Configuration
JWT_SECRET=emirates_lease_flow_super_secret_key_2024
JWT_EXPIRE=7d

# CORS Configuration
# Multiple origins can be specified, separated by comma (no spaces)
# Example: http://localhost:8080,https://yourdomain.com,https://app.yourdomain.com
# Local development: http://localhost:8080
# Production: https://realestate.globaldes.cloud
CORS_ORIGIN=http://localhost:8080,https://realestate.globaldes.cloud

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

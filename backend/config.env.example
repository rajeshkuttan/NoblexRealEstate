# DEVELOPMENT ENVIRONMENT CONFIGURATION EXAMPLE
# ==========================================
# Copy this file to config.env and update with your local settings
# cp config.env.example config.env

# Database Configuration - LOCAL DEVELOPMENT
DB_HOST=localhost
DB_PORT=3306
DB_NAME=HoldingDB
DB_USER=root
DB_PASSWORD=

# Server Configuration
PORT=5002
NODE_ENV=development

# JWT Configuration
# Generate a secret: openssl rand -base64 64
JWT_SECRET=emirates_lease_flow_super_secret_key_2024
JWT_EXPIRE=7d

# CORS Configuration - LOCAL DEVELOPMENT
# For local development, we allow both localhost and production for testing
CORS_ORIGIN=http://localhost:8080,https://realestate.globaldes.cloud

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Email Configuration (SMTP)
# For Gmail: Use App Password (not regular password)
# Enable 2FA on Gmail, then generate App Password at: https://myaccount.google.com/apppasswords
# For other providers: Use their SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# Email Settings
EMAIL_FROM=Emirates Lease Flow <noreply@emiratesleaseflow.com>
EMAIL_REPLY_TO=support@emiratesleaseflow.com

# Copilot (RAG Phase 2) — MySQL text retrieval; Qdrant/BullMQ deferred
COPILOT_ENABLED=true
COPILOT_DEFAULT_PROVIDER=openai
# OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
COPILOT_MAX_FILE_SIZE=10485760
COPILOT_ALLOWED_MIME_TYPES=application/pdf,text/plain,text/html,text/csv,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
# COPILOT_UPLOAD_DIR=
COPILOT_INDEXER_INTERVAL_MS=5000
COPILOT_RETRIEVAL_LIMIT=6
# Retrieval: mysql (default) | qdrant | hybrid
COPILOT_RETRIEVAL_MODE=mysql
# Embeddings: none (default) | stub | openai
COPILOT_EMBEDDING_PROVIDER=none
COPILOT_EMBEDDING_MODEL=text-embedding-3-small
COPILOT_EMBEDDING_DIMS=1536
# Optional Qdrant (only when COPILOT_RETRIEVAL_MODE=qdrant|hybrid)
# COPILOT_QDRANT_URL=http://localhost:6333
# COPILOT_QDRANT_COLLECTION=copilot_chunks
# COPILOT_QDRANT_API_KEY=
COPILOT_OCR_PROVIDER=stub
# COPILOT_USE_BULLMQ=true
# COPILOT_REDIS_URL=redis://localhost:6379
COPILOT_RELEASE_STAGE=rc1
COPILOT_USER_DAILY_MESSAGE_QUOTA=200
COPILOT_COMPANY_MONTHLY_MESSAGE_QUOTA=5000
COPILOT_ACTION_CONFIRM_TTL_MS=600000
# Vector store: mysql-text (Phase 2+). Qdrant planned for a later phase.

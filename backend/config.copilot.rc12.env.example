# Copilot RC1.2 production-like flags (merge into config.env — do not commit secrets)
# Native Redis 7 on localhost:6380; Qdrant on localhost:6333.
# docker-compose.copilot.yml is optional local-dev only.

COPILOT_ENABLED=true
COPILOT_RELEASE_STAGE=rc1
COPILOT_DEFAULT_PROVIDER=openai
COPILOT_PROMPT_VERSION=v1-erp-grounded

COPILOT_RETRIEVAL_MODE=hybrid
COPILOT_RETRIEVAL_LIMIT=6
COPILOT_EMBEDDING_PROVIDER=openai
COPILOT_EMBEDDING_MODEL=text-embedding-3-small
COPILOT_EMBEDDING_DIMS=1536

COPILOT_QDRANT_URL=http://127.0.0.1:6333
# Alias: QDRANT_URL=
COPILOT_QDRANT_COLLECTION=copilot_chunks
# COPILOT_QDRANT_API_KEY=
# QDRANT_API_KEY=

COPILOT_USE_BULLMQ=true
COPILOT_REDIS_URL=redis://127.0.0.1:6380
# Alias: REDIS_URL=
# With password: redis://:<password>@127.0.0.1:6380

# API process under PM2 ecosystem: set false so workers run in realestate-copilot-worker
# COPILOT_RUN_WORKERS=false

COPILOT_OCR_PROVIDER=stub
COPILOT_OCR_MIN_CHARS=40

COPILOT_USER_DAILY_MESSAGE_QUOTA=200
COPILOT_COMPANY_MONTHLY_MESSAGE_QUOTA=5000
COPILOT_ACTION_CONFIRM_TTL_MS=600000
COPILOT_LLM_FAILURE_THRESHOLD=5
COPILOT_LLM_COOLDOWN_MS=30000

COPILOT_INDEXER_INTERVAL_MS=5000
COPILOT_MAX_FILE_SIZE=10485760
